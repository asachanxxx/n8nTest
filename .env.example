# PostgreSQL — set automatically if you add a Railway Postgres plugin
# (Railway injects DATABASE_URL; the vars below can also be set manually)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=
DB_POSTGRESDB_USER=
DB_POSTGRESDB_PASSWORD=

# n8n port — Railway injects PORT at runtime; reference it with ${{PORT}}
N8N_PORT=${{PORT}}

# Basic auth
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Timezone
GENERIC_TIMEZONE=UTC
TZ=UTC

# Public URL for webhooks — use your Railway-generated domain
WEBHOOK_URL=https://<your-service>.up.railway.app
